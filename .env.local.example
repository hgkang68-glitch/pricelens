# .env.local — 복사해서 .env.local 로 저장 후 키 입력
# 절대 GitHub에 올리지 마세요!

# 네이버 쇼핑 검색 API (무료 · 일 25,000회)
# 발급: developers.naver.com
NAVER_CLIENT_ID=여기에_네이버_Client_ID
NAVER_CLIENT_SECRET=여기에_네이버_Client_Secret

# 쿠팡 파트너스 API (무료 · 시간당 10회)
# 발급: partners.coupang.com → 링크관리 → API
COUPANG_ACCESS_KEY=여기에_쿠팡_Access_Key
COUPANG_SECRET_KEY=여기에_쿠팡_Secret_Key

# 11번가 Open API (무료)
# 발급: openapi.11st.co.kr → 회원가입 → API 신청
ELEVENTH_API_KEY=여기에_11번가_API_Key

# G마켓 eBay Korea API (무료)
# 발급: developer.ebay.com → Application Keys
GMARKET_APP_ID=여기에_G마켓_App_ID
