# ── Supabase ──────────────────────────────────────────
# 발급: supabase.com → 프로젝트 → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── 네이버 쇼핑 검색 API ──────────────────────────────
NAVER_CLIENT_ID=여기에_네이버_Client_ID
NAVER_CLIENT_SECRET=여기에_네이버_Client_Secret

# ── 쿠팡 파트너스 API ────────────────────────────────
COUPANG_ACCESS_KEY=여기에_쿠팡_Access_Key
COUPANG_SECRET_KEY=여기에_쿠팡_Secret_Key

# ── 11번가 Open API ──────────────────────────────────
ELEVENTH_API_KEY=여기에_11번가_API_Key

# ── G마켓 eBay Korea API ─────────────────────────────
GMARKET_APP_ID=여기에_G마켓_App_ID

# ── Cron 보안 키 (아무 문자열이나 설정) ────────────────
CRON_SECRET=my-secret-cron-key-2025
